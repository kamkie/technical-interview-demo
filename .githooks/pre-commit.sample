#!/usr/bin/env sh
set -eu

# Optional local hook. Install with:
#   git config core.hooksPath .githooks
#   cp .githooks/pre-commit.sample .githooks/pre-commit
#
# Prerequisite:
#   JAVA_HOME points to JDK 25 in the current shell environment.

./gradlew spotlessCheck
./gradlew --no-problems-report pmdMain
./gradlew --no-problems-report test
