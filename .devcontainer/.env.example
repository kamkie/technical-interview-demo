# Development Container Environment Variables (Optional)
# Copy to .env and customize as needed

# PostgreSQL Configuration
POSTGRES_DB=technical_interview_demo
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=demo_password

# Application Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=technical_interview_demo
DATABASE_USER=demo_user
DATABASE_PASSWORD=demo_password

# Logging Configuration
LOGGING_LEVEL_ROOT=info
LOGGING_LEVEL_TEAM_JIT=debug
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=info
LOGGING_LEVEL_ORG_HIBERNATE_SQL=debug

# Spring Profiles
SPRING_PROFILES_ACTIVE=local

# Flyway Configuration
FLYWAY_BASELINE_ON_MIGRATE=false

# Prometheus Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus,metrics,configprops
MANAGEMENT_PROMETHEUS_METRICS_EXPORT_ENABLED=true

# Actuator Configuration
MANAGEMENT_ENDPOINTS_WEB_BASE_PATH=/actuator
MANAGEMENT_HEALTH_PROBES_ENABLED=true

# Timezone (UTC recommended for consistency)
TZ=UTC

