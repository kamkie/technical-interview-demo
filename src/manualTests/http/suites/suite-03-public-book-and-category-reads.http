@baseUrl = http://localhost:8080
@report = no-report-available
@report_file = ../reports/fake_report.md
@test_idx = 1
@firstBookId = 0
@firstCategoryId = 1

### Suite 03 — Public Book and Category Reads
# @name suite_03_setup
GET {{baseUrl}}/hello

> {%
    var date = new Date().toISOString().split('T')[0];
    client.global.set("report_file", "../reports/03-public-book-and-category-reads_raport_" + date + ".md");
    var report = "# Manual Regression Report - Suite 03\n\n";
    report += "- Suite: `03-public-book-and-category-reads`\n";
    report += "- Run Date: " + new Date().toString() + "\n";
    report += "- Base URL: " + client.global.get("baseUrl") + "\n\n";
    report += "## Test Results\n\n";
    report += "| # | Test | Method | Path | Status | Result | Note |\n";
    report += "|---|------|--------|------|--------|--------|------|\n";
    client.global.set("report", report);
    client.global.set("test_idx", 1);
%}

### 03-1 List Books
# @name list_books
GET {{baseUrl}}/api/books?page=0&size=5&sort=title,asc
Accept: application/json

> {%
    var idx = client.global.get("test_idx") || 1;
    var report = client.global.get("report") || "";
    var result = response.status === 200 ? "PASS" : "FAIL";
    report += "| " + idx + " | listBooksWithPagination | GET | /api/books | " + response.status + " | " + result + " | public book list |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    if (response.body && response.body.content && response.body.content.length > 0) {
        client.global.set("firstBookId", response.body.content[0].id);
        client.log("Captured firstBookId: " + response.body.content[0].id);
    }
%}

### 03-2 List Categories
# @name list_categories
GET {{baseUrl}}/api/categories
Accept: application/json

> {%
    var idx = client.global.get("test_idx") || 1;
    var report = client.global.get("report") || "";
    var result = response.status === 200 ? "PASS" : "FAIL";
    report += "| " + idx + " | listCategories | GET | /api/categories | " + response.status + " | " + result + " | public category list |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    var items = response.body && (response.body.content || response.body);
    if (items && items.length > 0) {
        client.global.set("firstCategoryId", items[0].id);
        client.log("Captured firstCategoryId: " + items[0].id);
    }
%}

### Finalize Report
POST {{baseUrl}}/debug/echo
Content-Type: text/plain

{{report}}

>>! {{report_file}}

> {%
    client.log("Report saved to: " + client.global.get("report_file"));
    client.log(client.global.get("report"));
%}
