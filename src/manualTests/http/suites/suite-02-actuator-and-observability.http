    });
%}

### 02-5 Prometheus Scrape
# @name actuator_prometheus
GET {{baseUrl}}/actuator/prometheus
Accept: text/plain

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var hasContent = response.body && response.body.length > 0;
    var result = (response.status === 200 && hasContent) ? "PASS" : "FAIL";
    report += "| " + idx + " | prometheusScrape | GET | /actuator/prometheus | " + response.status + " | " + result + " | prometheus scrape |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200 and has content", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(hasContent, "Body is empty");
    });
%}

### Finalize Report
POST {{baseUrl}}/debug/echo
Content-Type: text/plain

{{report}}

>>! {{report_file}}

> {%
    client.log("Report saved to: " + client.global.get("report_file"));
    client.log(client.global.get("report"));
%}
