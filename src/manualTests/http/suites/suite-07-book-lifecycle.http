@baseUrl = http://localhost:8080
@csrfToken = not-captured-run-setup-request-first
@report = no-report-available
@report_file = ../reports/fake_report.md
@test_idx = 1
@runTag = no-tag
@createdBookIsbn = no-isbn
@createdBookId = 0
@createdBookVersion = 0
@firstCategoryId = 1
@firstCategoryName = Java

### Suite 07 — Book Lifecycle
# @name suite_07_setup
GET {{baseUrl}}/api/session
Cookie: technical-interview-demo-session={{sessionCookie}}

> {%
    var date = new Date().toISOString().split('T')[0];
    client.global.set("report_file", "../reports/07-book-lifecycle_raport_" + date + ".md");
    var baseUrl = client.variables.environment.get("baseUrl") || client.global.get("baseUrl") || client.variables.file.get("baseUrl");
    var report = "# Manual Regression Report - Suite 07\n\n";
    report += "- Suite: `07-book-lifecycle`\n";
    report += "- Run Date: " + new Date().toString() + "\n";
    report += "- Base URL: " + baseUrl + "\n\n";
    report += "## Test Results\n\n";
    report += "| # | Test | Method | Path | Status | Result | Note |\n";
    report += "|---|------|--------|------|--------|--------|------|\n";
    client.global.set("report", report);
    client.global.set("test_idx", 1);

    function getCookieValue(name) {
        if (typeof response.cookiesByName === "function") {
            var cookies = response.cookiesByName(name);
            if (cookies && cookies.length > 0) {
                return cookies[0].value;
            }
        }

        var setCookieHeaders = [];
        if (response.headers && typeof response.headers.valuesOf === "function") {
            setCookieHeaders = response.headers.valuesOf("Set-Cookie") || [];
        } else if (response.headers && typeof response.headers.valueOf === "function") {
            var setCookieHeader = response.headers.valueOf("Set-Cookie");
            if (setCookieHeader) {
                setCookieHeaders = [setCookieHeader];
            }
        }

        for (var i = 0; i < setCookieHeaders.length; i++) {
            var parts = String(setCookieHeaders[i]).split(";");
            var nameAndValue = parts[0].split("=");
            if (nameAndValue[0] === name) {
                return nameAndValue.slice(1).join("=");
            }
        }

        return null;
    }

    var csrfToken = getCookieValue("XSRF-TOKEN");
    if (csrfToken) {
        client.global.set("csrfToken", csrfToken);
        client.log("Captured XSRF-TOKEN from response.");
    } else {
        client.log("XSRF-TOKEN cookie not found in response. Using existing global csrfToken if available.");
    }

    var tag = "HTTP-" + Math.floor(Math.random() * 10000);
    client.global.set("runTag", tag);
    var isbn = "978-MR-" + Math.floor(Math.random() * 1000000000);
    client.global.set("createdBookIsbn", isbn);
%}

### 07-0 Resolve Category
# @name resolve_category
GET {{baseUrl}}/api/categories
Accept: application/json

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    var items = response.body && (response.body.content || response.body);
    if (items && items.length > 0) {
        client.global.set("firstCategoryId", items[0].id);
        client.global.set("firstCategoryName", items[0].name);
        client.log("Captured firstCategoryName: " + items[0].name);
    }
%}

### 07-1 Create Book
# @name create_book
< {%
    request.variables.set("requestCsrfToken", client.global.get("csrfToken"));
    request.variables.set("requestRunTag", client.global.get("runTag") || client.variables.file.get("runTag"));
    request.variables.set("requestCreatedBookIsbn", client.global.get("createdBookIsbn") || client.variables.file.get("createdBookIsbn"));
    request.variables.set("requestFirstCategoryName", client.global.get("firstCategoryName") || client.variables.file.get("firstCategoryName"));
%}
POST {{baseUrl}}/api/books
Cookie: technical-interview-demo-session={{sessionCookie}}; XSRF-TOKEN={{requestCsrfToken}}
X-XSRF-TOKEN: {{requestCsrfToken}}
Content-Type: application/json

{
  "title": "Manual Regression Book {{requestRunTag}}",
  "author": "Manual Regression",
  "isbn": "{{requestCreatedBookIsbn}}",
  "publicationYear": 2025,
  "categories": ["{{requestFirstCategoryName}}"]
}

> {%
    var idx = client.global.get("test_idx") || 1;
    var report = client.global.get("report") || "";
    var validStatuses = [200, 201];
    var result = validStatuses.includes(response.status) ? "PASS" : "FAIL";
    report += "| " + idx + " | createBook_returnsLocationOrEntity | POST | /api/books | " + response.status + " | " + result + " | create book |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200 or 201", function() {
        client.assert(validStatuses.includes(response.status), "Response status is not 200 or 201");
    });

    var createdBookId = response.body && response.body.id;
    if (!createdBookId && response.headers && typeof response.headers.valueOf === "function") {
        var location = response.headers.valueOf("Location");
        var locationMatch = location && String(location).match(/\/api\/books\/(\d+)$/);
        if (locationMatch) {
            createdBookId = Number(locationMatch[1]);
        }
    }

    if (createdBookId) {
        client.global.set("createdBookId", createdBookId);
        client.global.set("createdBookVersion", response.body && response.body.version || 0);
    }
%}

### 07-2 Read Book
# @name read_book
< {%
    request.variables.set("requestCreatedBookId", client.global.get("createdBookId") || client.variables.file.get("createdBookId"));
%}
GET {{baseUrl}}/api/books/{{requestCreatedBookId}}
Cookie: technical-interview-demo-session={{sessionCookie}}
Accept: application/json

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var result = response.status === 200 ? "PASS" : "FAIL";
    report += "| " + idx + " | readCreatedBookById_returnsIt | GET | /api/books/" + client.global.get("createdBookId") + " | " + response.status + " | " + result + " | read created book |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### 07-3 Update Book
# @name update_book
< {%
    request.variables.set("requestCsrfToken", client.global.get("csrfToken"));
    request.variables.set("requestCreatedBookId", client.global.get("createdBookId") || client.variables.file.get("createdBookId"));
    request.variables.set("requestCreatedBookVersion", client.global.get("createdBookVersion") || client.variables.file.get("createdBookVersion"));
    request.variables.set("requestRunTag", client.global.get("runTag") || client.variables.file.get("runTag"));
%}
PUT {{baseUrl}}/api/books/{{requestCreatedBookId}}
Cookie: technical-interview-demo-session={{sessionCookie}}; XSRF-TOKEN={{requestCsrfToken}}
X-XSRF-TOKEN: {{requestCsrfToken}}
Content-Type: application/json

{
  "title": "Manual Regression Book {{requestRunTag}} (updated)",
  "author": "Manual Regression",
  "version": {{requestCreatedBookVersion}},
  "publicationYear": 2026
}

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var validStatuses = [200, 204];
    var result = validStatuses.includes(response.status) ? "PASS" : "FAIL";
    report += "| " + idx + " | updateCreatedBookTitle | PUT | /api/books/" + client.global.get("createdBookId") + " | " + response.status + " | " + result + " | update created book |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200 or 204", function() {
        client.assert(validStatuses.includes(response.status), "Response status is not 200 or 204");
    });

    if (response.body.version) {
        client.global.set("createdBookVersion", response.body.version);
    }
%}

### 07-4 Delete Book
# @name delete_book
< {%
    request.variables.set("requestCsrfToken", client.global.get("csrfToken"));
    request.variables.set("requestCreatedBookId", client.global.get("createdBookId") || client.variables.file.get("createdBookId"));
%}
DELETE {{baseUrl}}/api/books/{{requestCreatedBookId}}
Cookie: technical-interview-demo-session={{sessionCookie}}; XSRF-TOKEN={{requestCsrfToken}}
X-XSRF-TOKEN: {{requestCsrfToken}}

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var validStatuses = [200, 204];
    var result = validStatuses.includes(response.status) ? "PASS" : "FAIL";
    report += "| " + idx + " | deleteCreatedBookAndAssertNotFound (Delete) | DELETE | /api/books/" + client.global.get("createdBookId") + " | " + response.status + " | " + result + " | delete created book |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 200 or 204", function() {
        client.assert(validStatuses.includes(response.status), "Response status is not 200 or 204");
    });
%}

### 07-5 Verify Deleted
# @name verify_deleted
< {%
    request.variables.set("requestCreatedBookId", client.global.get("createdBookId") || client.variables.file.get("createdBookId"));
%}
GET {{baseUrl}}/api/books/{{requestCreatedBookId}}
Cookie: technical-interview-demo-session={{sessionCookie}}
Accept: application/json

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var result = response.status === 404 ? "PASS" : "FAIL";
    report += "| " + idx + " | deleteCreatedBookAndAssertNotFound (Verify) | GET | /api/books/" + client.global.get("createdBookId") + " | " + response.status + " | " + result + " | verify deleted book is gone |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 404", function() {
        client.assert(response.status === 404, "Response status is not 404");
    });
%}

### Finalize Report
< {%
    request.variables.set("reportBody", client.global.get("report") || client.variables.file.get("report"));
    request.variables.set("reportFile", client.global.get("report_file") || client.variables.file.get("report_file"));
%}
POST {{baseUrl}}/debug/echo
Content-Type: text/plain

{{reportBody}}

>>! {{reportFile}}

> {%
    client.log("Report saved to: " + (client.global.get("report_file") || client.variables.file.get("report_file")));
    client.log(client.global.get("report") || client.variables.file.get("report"));
%}
