### 05-5 Anonymous Create Category
# @name create_category_anon
POST {{baseUrl}}/api/categories
Content-Type: application/json
Accept: application/json

{
  "name": "manual-regression-anon"
}

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var validStatuses = [401, 403];
    var result = validStatuses.includes(response.status) ? "PASS" : "FAIL";
    report += "| " + idx + " | createCategory_anonymous | POST | /api/categories | " + response.status + " | " + result + " | anonymous POST /api/categories |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 401 or 403", function() {
        client.assert(validStatuses.includes(response.status), "Response status is not 401 or 403");
    });
%}

### Finalize Report
GET {{baseUrl}}/hello

> {%
    client.log(client.global.get("report"));
%}
