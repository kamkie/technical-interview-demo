@baseUrl = http://localhost:8080

### Suite 05 — Anonymous Negative Access
# @name suite_05_setup
GET {{baseUrl}}/hello

> {%
    var date = new Date().toISOString().split('T')[0];
    client.global.set("report_file", "05-anonymous-negative-access_raport_" + date + ".md");
    var report = "# Manual Regression Report - Suite 05\n\n";
    report += "- Suite: `05-anonymous-negative-access`\n";
    report += "- Run Date: " + new Date().toString() + "\n";
    report += "- Base URL: " + client.global.get("baseUrl") + "\n\n";
    report += "## Test Results\n\n";
    report += "| # | Test | Method | Path | Status | Result | Note |\n";
    report += "|---|------|--------|------|--------|--------|------|\n";
    client.global.set("report", report);
    client.global.set("test_idx", 1);
%}

### 05-1 Anonymous Account Read
# @name get_account_anon
GET {{baseUrl}}/api/account
Accept: application/json

> {%
    var idx = client.global.get("test_idx");
    var report = client.global.get("report");
    var result = response.status === 401 ? "PASS" : "FAIL";
    report += "| " + idx + " | getAccount_anonymous | GET | /api/account | " + response.status + " | " + result + " | anonymous /api/account |\n";
    client.global.set("report", report);
    client.global.set("test_idx", idx + 1);

    client.test("Status is 401", function() {
        client.assert(response.status === 401, "Response status is not 401");
    });
%}

