  "components" : {
    "schemas" : {
      "UserLanguagePreferenceRequest" : {
        "type" : "object",
        "properties" : {
          "preferredLanguage" : {
            "type" : "string",
            "description" : "Two-letter ISO 639-1 language code. Use null or blank to clear the preference.",
            "example" : "pl"
          }
        },
        "description" : "Payload for updating the current user's preferred language."
      },
      "UserProfileResponse" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "description" : "Database identifier.",
            "format" : "int64",
            "example" : 1
          },
          "provider" : {
            "type" : "string",
            "description" : "OAuth provider name.",
            "example" : "github"
          },
          "login" : {
            "type" : "string",
            "description" : "GitHub login.",
            "example" : "kamkie"
          },
          "displayName" : {
            "type" : "string",
            "description" : "Display name from the OAuth provider.",
            "example" : "Kamil Kiewisz"
          },
          "email" : {
            "type" : "string",
            "description" : "Email address when available from the provider."
          },
          "preferredLanguage" : {
            "type" : "string",
            "description" : "Preferred two-letter language code used as the last localization fallback."
          },
          "roles" : {
            "type" : "array",
            "description" : "Roles assigned to the persisted user.",
            "items" : {
              "type" : "string",
              "description" : "Granted role name.",
              "example" : "USER"
            }
          },
          "lastLoginAt" : {
            "type" : "string",
            "description" : "Timestamp of the latest authenticated request.",
            "format" : "date-time"
          },
          "createdAt" : {
            "type" : "string",
            "description" : "Creation timestamp.",
            "format" : "date-time"
          },
          "updatedAt" : {
            "type" : "string",
            "description" : "Last update timestamp.",
            "format" : "date-time"
          }
        },
        "description" : "Persisted application profile for the current authenticated user."
      },
      "LocalizationMessageRequest" : {
        "required" : [ "language", "messageKey", "messageText" ],
        "type" : "object",
        "properties" : {
          "messageKey" : {
            "maxLength" : 150,
            "minLength" : 0,
            "pattern" : "^[a-z0-9._-]+$",
            "type" : "string",
            "description" : "Stable message key managed by the application.",
            "example" : "error.request.resource_not_found"
          },
          "language" : {
            "minLength" : 1,
            "pattern" : "^[a-zA-Z]{2}$",
            "type" : "string",
            "description" : "Two-letter ISO 639-1 language code.",
            "example" : "pl"
          },
          "messageText" : {
            "maxLength" : 2000,
            "minLength" : 0,
            "type" : "string",
            "description" : "Localized message text.",
            "example" : "Nie znaleziono zasobu."
          },
          "description" : {
            "maxLength" : 1000,
            "minLength" : 0,
            "type" : "string",
            "description" : "Optional reviewer-facing description.",
            "example" : "Displayed when a requested resource does not exist."
          }
        },
        "description" : "Payload for creating or updating a localization message."
      },
      "LocalizationMessageResponse" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "description" : "Database identifier.",
            "format" : "int64",
            "example" : 1
          },
          "messageKey" : {
            "type" : "string",
            "description" : "Stable message key.",
            "example" : "error.request.resource_not_found"
          },
          "language" : {
            "type" : "string",
            "description" : "Two-letter ISO 639-1 language code.",
            "example" : "en"
          },
          "messageText" : {
            "type" : "string",
            "description" : "Localized message text.",
            "example" : "The requested resource was not found."
          },
          "description" : {
            "type" : "string",
            "description" : "Optional reviewer-facing description."
          },
          "createdAt" : {
            "type" : "string",
            "description" : "Creation timestamp.",
            "format" : "date-time"
          },
          "updatedAt" : {
            "type" : "string",
            "description" : "Last update timestamp.",
            "format" : "date-time"
          }
        },
        "description" : "Localization message returned by the API."
      },
      "BookUpdateRequest" : {
        "required" : [ "author", "publicationYear", "title", "version" ],
        "type" : "object",
        "properties" : {
          "title" : {
            "minLength" : 1,
            "type" : "string",
            "description" : "Book title.",
            "example" : "Effective Java, Third Edition"
          },
          "author" : {
            "minLength" : 1,
            "type" : "string",
            "description" : "Primary author.",
            "example" : "Joshua Bloch"
          },
          "version" : {
            "type" : "integer",
            "description" : "Current optimistic-lock version.",
            "format" : "int64",
            "example" : 0
          },
          "publicationYear" : {
            "type" : "integer",
            "description" : "Publication year.",
            "format" : "int32",
            "example" : 2018
          },
          "categories" : {
            "type" : "array",
            "description" : "Optional replacement list of existing category names.",
            "items" : {
              "type" : "string",
              "description" : "Existing category name.",
              "example" : "Java"
            }
          }
        },
        "description" : "Payload for updating an existing book. ISBN remains immutable."
      },
      "Book" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "description" : "Database identifier.",
            "format" : "int64",
            "example" : 1
          },
          "version" : {
            "type" : "integer",
            "description" : "Optimistic-lock version used for updates.",
            "format" : "int64",
            "example" : 0
          },
          "title" : {
            "type" : "string",
            "description" : "Book title.",
            "example" : "Effective Java"
          },
          "author" : {
            "type" : "string",
            "description" : "Primary author.",
            "example" : "Joshua Bloch"
          },
          "isbn" : {
            "type" : "string",
            "description" : "Unique ISBN assigned at creation time.",
            "example" : "9780134685991"
          },
          "publicationYear" : {
            "type" : "integer",
            "description" : "Publication year.",
            "format" : "int32",
            "example" : 2018
          },
          "categories" : {
            "uniqueItems" : true,
            "type" : "array",
