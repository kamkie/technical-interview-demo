# IntelliJ HTTP Client examples for technical-interview-demo
# This app does not issue JWTs and does not accept Authorization: Bearer tokens.
# Protected app requests use the configured OAuth provider login flow plus the
# technical-interview-demo-session cookie created by Spring Session.
# The supported first-party browser contract assumes one public origin via reverse proxy.
# Unsafe same-site writes also require the readable XSRF token from GET /api/session
# to be mirrored into the X-XSRF-TOKEN header.
#
# Provider token exchange examples are for diagnostics only.
# External provider access tokens are for provider APIs, not for this app,
# and the app will not accept those tokens on /api/**.

@baseUrl = http://localhost:8080
@oauthProvider = github
#@sessionCookie = paste-technical-interview-demo-session-here
# csrfToken is captured automatically by the authenticated GET /api/session request below.
#@providerClientId = paste-provider-client-id-here
#@providerClientSecret = paste-provider-client-secret-here
#@providerAuthCode = paste-provider-auth-code-here
#@providerAccessToken = paste-provider-access-token-here

### App session contract - inspect the current same-site browser session state
# Use this endpoint to discover the current `loginProviders[]` contract instead of
# hard-coding provider authorization paths into the client. The response also sets
# `XSRF-TOKEN=<token>` and reports `csrf.cookieName=XSRF-TOKEN` plus
# `csrf.headerName=X-XSRF-TOKEN`.
# This is step 1 of the supported browser flow.
GET {{baseUrl}}/api/session
Accept: application/json

### App authentication - start the optional OAuth login flow in a browser-capable client
# This endpoint is active only when the oauth profile is enabled and the provider registration exists.
# In the real UI flow, read the relative `authorizationPath` from `GET /api/session`
# instead of hard-coding `@oauthProvider`. The variable stays here for reviewer convenience.
GET {{baseUrl}}/api/session/oauth2/authorization/{{oauthProvider}}

### App session contract - inspect the authenticated same-site browser session state
# This request stores the `XSRF-TOKEN` cookie value as the global `csrfToken` variable.
# Run it after login and again after logout or a fresh login before the next unsafe write.
# This is the required authenticated bootstrap/refresh step before `PUT`, `POST`, or `DELETE` on `/api/**`.
GET {{baseUrl}}/api/session
Cookie: technical-interview-demo-session={{sessionCookie}}
Accept: application/json

> {%
const csrfCookie = response.cookiesByName("XSRF-TOKEN")[0];
if (csrfCookie) {
  client.global.set("csrfToken", csrfCookie.value);
  client.log("Updated csrfToken from XSRF-TOKEN.");
} else {
  client.log("No XSRF-TOKEN cookie was returned; csrfToken was not updated.");
}
%}

### App authentication - verify the authenticated app session cookie
# `GET /api/account` remains the authenticated persisted-profile read, not the bootstrap endpoint.
GET {{baseUrl}}/api/account
Cookie: technical-interview-demo-session={{sessionCookie}}
Accept: application/json

### App authentication - log out the current app session
# The logout contract is idempotent and still returns 204 when no session exists.
# When a real current session exists, send both the session cookie and X-XSRF-TOKEN.
# After logout, call GET /api/session again before the next login-backed unsafe write.
POST {{baseUrl}}/api/session/logout
Cookie: technical-interview-demo-session={{sessionCookie}}
X-XSRF-TOKEN: {{csrfToken}}

> {%
client.global.clear("csrfToken");
client.log("Cleared csrfToken after logout. Run the authenticated GET /api/session request before the next unsafe write.");
%}

### Next step
