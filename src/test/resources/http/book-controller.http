# IntelliJ HTTP Client examples for technical-interview-demo
# Public GET requests work as-is.
# Protected requests require the app to run with the oauth profile, an authenticated session,
# and a matching CSRF token from that same browser session.

@baseUrl = http://localhost:8080
@sessionCookie = paste-technical-interview-demo-session-here
@csrfToken = paste-x-csrf-token-here
@bookId = 1
@bookVersion = 0
@writeBookId = 0
@writeBookVersion = 0
@demoBookIsbn = demo-book-change-me-if-rerunning

### BookController - list books with pagination and sorting
GET {{baseUrl}}/api/books?page=0&size=5&sort=title,asc&sort=year,desc
Accept: application/json

### BookController - filter by title, author, category, and year range
GET {{baseUrl}}/api/books?title=clean&author=martin&category=java&yearFrom=2000&yearTo=2020
Accept: application/json

### BookController - load one seeded book and capture its id/version for read examples
GET {{baseUrl}}/api/books?page=0&size=1&sort=id,asc
Accept: application/json
> {%
const books = response.body.content;
if (books && books.length > 0) {
  const firstBook = books[0];
  client.global.set("bookId", String(firstBook.id));
  client.global.set("bookVersion", String(firstBook.version));
}
%}

### BookController - get book by id
GET {{baseUrl}}/api/books/{{bookId}}
Accept: application/json

### BookController - create book (authenticated + CSRF)
POST {{baseUrl}}/api/books
Cookie: technical-interview-demo-session={{sessionCookie}}
X-CSRF-TOKEN: {{csrfToken}}
Content-Type: application/json
Accept: application/json

{
  "title": "Spring in Action",
  "author": "Craig Walls",
  "isbn": "{{demoBookIsbn}}",
  "publicationYear": 2022,
  "categories": ["Java", "Software Engineering"]
}
> {%
if (response.status === 201) {
  client.global.set("writeBookId", String(response.body.id));
  client.global.set("writeBookVersion", String(response.body.version));
}
%}

### BookController - update the book created above (run create first)
PUT {{baseUrl}}/api/books/{{writeBookId}}
Cookie: technical-interview-demo-session={{sessionCookie}}
X-CSRF-TOKEN: {{csrfToken}}
Content-Type: application/json
Accept: application/json

{
  "title": "Spring in Action, Second Edition",
  "author": "Craig Walls",
  "version": {{writeBookVersion}},
  "publicationYear": 2026,
  "categories": ["Java"]
}
> {%
if (response.status === 200) {
  client.global.set("writeBookVersion", String(response.body.version));
}
%}

### BookController - delete the book created above (run create first)
DELETE {{baseUrl}}/api/books/{{writeBookId}}
Cookie: technical-interview-demo-session={{sessionCookie}}
X-CSRF-TOKEN: {{csrfToken}}
