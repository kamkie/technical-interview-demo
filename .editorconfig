root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
tab_width = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{md,adoc,asciidoc}]
# Documentation uses prose-friendly wrapping.
max_line_length = off

[*.{json,jsonc,yml,yaml}]
# Structured data uses conventional two-space indentation.
indent_size = 2
ij_yaml_spaces_within_braces = false
ij_yaml_spaces_within_brackets = false

[*.properties]
# Preserve blank-line separators during reformatting.
ij_properties_keep_blank_lines = true

[*.csv]
indent_style = tab

# Generated or externally managed files should not be reformatted.
[gradlew]
ij_formatter_enabled = false

[.agents/**]
ij_formatter_enabled = false

[src/gatling/resources/gatling-benchmark-baseline.json]
ij_formatter_enabled = false

[src/main/resources/db/migration/*]
ij_formatter_enabled = false

[src/test/resources/openapi/approved-openapi.json]
ij_formatter_enabled = false
