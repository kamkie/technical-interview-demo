# Optional local shell environment template.
# Spring Boot does not load this file automatically. Export the values in your shell,
# use your IDE run configuration, or have Docker Compose reference them explicitly.

# Java 25 toolchain
JAVA_HOME=C:\Users\kamki\.jdks\azul-25.0.3

# Optional IntelliJ formatter integration for Spotless
IDEA_HOME=C:\Path\To\IntelliJ IDEA
IDEA_FORMATTER_BINARY=C:\Path\To\IntelliJ IDEA\bin\idea64.exe

# Default local profile
SPRING_PROFILES_ACTIVE=local

# PostgreSQL settings for local and prod profiles
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=technical_interview_demo
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme
