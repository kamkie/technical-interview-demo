# Optional local shell environment template.
#
# Copy this to .env and fill in your local values.
# build.ps1 and build.sh auto-load the root .env before Gradle commands.
# For direct PowerShell commands, source it manually:
#   . ./scripts/load-dotenv.ps1 -Quiet
#
# Or add to your PowerShell profile for auto-loading:
#   . ./scripts/init-shell-env.ps1
#
# Spring Boot does not load this file automatically. The scripts above
# export the values to your shell, configure your IDE run configuration,
# or have Docker Compose reference them explicitly.

# Java 25 toolchain
# REQUIRED: Replace with your JDK 25 installation directory.
# Examples:
#   Windows: C:\Program Files\Eclipse Temurin\jdk-25.0.0
#   IntelliJ JBR: C:\Users\<user>\AppData\Local\Programs\IntelliJ IDEA Ultimate\jbr
#   WSL2: /usr/lib/jvm/java-25-openjdk-amd64
JAVA_HOME=<path-to-jdk-25>

# Default local profile
SPRING_PROFILES_ACTIVE=local

# Uncomment and adjust if you want GitHub OAuth login for protected write endpoints
# SPRING_PROFILES_ACTIVE=local,oauth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# ADMIN_LOGINS=your-github-login,another-admin-login

# PostgreSQL settings for local and prod profiles
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=technical_interview_demo
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme

# GitHub OAuth settings (Optional, use with oauth profile)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Default local profile
SPRING_PROFILES_ACTIVE=local

# OAuth provider setting
OAUTH_DEFAULT_PROVIDER=github

# Production session-cookie override for HTTPS deployments
SESSION_COOKIE_SECURE=true
